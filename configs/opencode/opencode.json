    "demo_creator": {
      "description": "Developer advocate. Creates minimal, runnable code examples. Only communication-phase agent with compiler and runtime access.",
      "mode": "subagent",
      "model": "juspay-grid/glm-latest",
      "prompt": "{file:/home/opencode/.config/opencode/.opencode/agents/demo_creator.md}",
      "steps": 1500,
      "temperature": 0.2,
      "permission": {
        "edit": "allow",
        "bash": {
