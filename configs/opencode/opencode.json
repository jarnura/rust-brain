        "mcp_rustbrain_context_store": true
      }
    },
    "blog_writer": {
      "description": "Technical writer for external publication. Transforms engineering artifacts into blog posts. Verifies all code examples against actual codebase via pg_query.",
      "mode": "subagent",
      "model": "juspay-grid/glm-latest",
      "prompt": "{file:/home/opencode/.config/opencode/.opencode/agents/blog_writer.md}",
      "steps": 1500,
      "temperature": 0.4,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "cat *": "allow",
