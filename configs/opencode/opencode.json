  "command": {
    "research": {
      "description": "Research a topic using embedded docs and external sources",
      "template": "Research the following topic deeply using all available knowledge sources:\n\n$ARGUMENTS\n\nReturn a structured ResearchBrief with credibility-tagged findings, synthesis, and open questions.",
      "agent": "research"
    },
    "explore": {
      "description": "Explore the codebase for a specific component or pattern",
      "template": "Explore the codebase to understand:\n\n$ARGUMENTS\n\nProduce a CodeMap with symbols, relationships, module boundaries, and a context summary.",
      "agent": "explorer"
    },
    "investigate": {
      "description": "CLASS A: Full understanding \u2014 orchestrator runs research + explorer in parallel",
      "template": "Investigate the following thoroughly:\n\n$ARGUMENTS\n\nClassify as CLASS A. Run Research and Explorer in parallel, merge results into a unified answer.",
      "agent": "orchestrator"
    },
    "plan": {
      "description": "CLASS B: Understand + plan \u2014 produces an ImplementationPlan for review",
      "template": "Plan the implementation for:\n\n$ARGUMENTS\n\nClassify as CLASS B. Run understand phase, then produce an ImplementationPlan with ordered changes, risk matrix, and test plan. Present for approval before any mutations.",
      "agent": "orchestrator"
    },
    "build": {
      "description": "CLASS C: Understand + plan + build \u2014 requires human confirmation before writes",
      "template": "Implement the following:\n\n$ARGUMENTS\n\nClassify as CLASS C. Run understand \u2192 plan \u2192 build cycle with Developer \u21c4 Reviewer loop. Request human confirmation before filesystem writes.",
      "agent": "orchestrator"
    },
    "ship": {
      "description": "CLASS D: Full pipeline \u2014 build + test + deploy with human gates",
      "template": "Ship the following:\n\n$ARGUMENTS\n\nClassify as CLASS D. Run full pipeline: understand \u2192 plan \u2192 build \u2192 test \u2192 deploy. Requires human confirmation at build and deploy stages.",
      "agent": "orchestrator"
    },
    "debug": {
      "description": "Diagnose a specific error or test failure",
      "template": "Diagnose the following error:\n\n$ARGUMENTS\n\nTrace the error backward through the call chain. Identify root cause vs symptom. Route the fix to the correct agent.",
      "agent": "debugger"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  }
}