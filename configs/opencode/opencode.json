{
  "$schema": "https://opencode.ai/config.json",
  "model": "juspay-grid/glm-latest",
  "small_model": "juspay-grid/glm-latest",
  "default_agent": "orchestrator",
  "mcp": {
    "rustbrain": {
      "type": "remote",
      "url": "http://mcp-sse:3001/sse"
    }
  },
  "provider": {
    "juspay-grid": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM Proxy",
      "options": {
        "baseURL": "https://grid.ai.juspay.net",
        "apiKey": "sk-xCWCWvNq6kno_3KSEIU8lQ"
      },
      "models": {
        "glm-latest": {
          "name": "GLM Latest",
          "limit": {
            "context": 128000,
            "output": 16000
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        },
        "kimi-latest": {
          "name": "Kimi Latest",
          "limit": {
            "context": 128000,
            "output": 16000
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "instructions": [
    "You are part of a multi-agent SDLC automation system for Rust codebases, powered by rust-brain.",
    "rust-brain MCP tools provide code intelligence: search_code, get_function, get_callers, get_trait_impls, find_type_usages, get_module_tree, query_graph, find_calls_with_type, find_trait_impls_for_type, pg_query, context_store, status_check, task_update.",
    "Use MCP tools for code intelligence queries. Use bash for filesystem, compiler, and git operations.",
    "Follow your agent-specific system prompt strictly. Never exceed your tool budgets."
  ],
  "agent": {
    "orchestrator": {
      "description": "Control plane. Classifies intent (CLASS A-E), decomposes into task DAGs, dispatches to specialist agents, tracks artifacts via context_store. Never writes code or reads source files.",
      "mode": "primary",
      "model": "juspay-grid/kimi-latest",
      "prompt": "{file:/home/opencode/.config/opencode/.opencode/agents/orchestrator.md}",
      "steps": 2000,
      "temperature": 0.3,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git status": "allow",
          "git log --oneline*": "allow"
        },
        "webfetch": "deny",
        "task": {
          "*": "allow"
        }
      },
      "tools": {
        "mcp_rustbrain_context_store": true,
        "mcp_rustbrain_status_check": true,
        "mcp_rustbrain_task_update": true
      }
    },
    "research": {
      "description": "Knowledge retrieval specialist. Searches embedded docs, ecosystem resources, external references. Produces ResearchBrief with credibility-tagged findings. Never reads source code.",
      "mode": "subagent",
      "model": "juspay-grid/glm-latest",
      "prompt": "{file:/home/opencode/.config/opencode/.opencode/agents/research.md}",
      "steps": 2000,
      "temperature": 0.2,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        },
        "webfetch": "allow",
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "mcp_rustbrain_search_code": true,
        "mcp_rustbrain_get_function": true,
        "mcp_rustbrain_query_graph": true,
        "mcp_rustbrain_pg_query": true,
        "mcp_rustbrain_context_store": true
      }
    },
    "explorer": {
      "description": "Codebase cartographer. Navigates code via graph queries, indexed lookups, semantic search, and targeted file reads. Produces CodeMap. Read-only \u2014 never modifies files.",
      "mode": "subagent",
      "model": "juspay-grid/glm-latest",
      "prompt": "{file:/home/opencode/.config/opencode/.opencode/agents/explorer.md}",
      "steps": 1000,
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "ls *": "allow",
          "ls": "allow",
          "find *": "allow",
          "fd *": "allow",
          "wc *": "allow",
          "tree *": "allow",
          "tree": "allow",
          "stat *": "allow",
          "cargo metadata*": "allow",
          "cargo tree*": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git blame*": "allow"
        },
        "webfetch": "deny",
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "mcp_rustbrain_search_code": true,
        "mcp_rustbrain_get_function": true,
        "mcp_rustbrain_get_callers": true,
        "mcp_rustbrain_get_trait_impls": true,
        "mcp_rustbrain_find_type_usages": true,
        "mcp_rustbrain_get_module_tree": true,
        "mcp_rustbrain_find_calls_with_type": true,
        "mcp_rustbrain_find_trait_impls_for_type": true,
        "mcp_rustbrain_context_store": true
      }
    },
    "planner": {
      "description": "Architect. Translates ResearchBrief + CodeMap into ordered, dependency-aware ImplementationPlan. Read-only \u2014 specifies changes but never implements them.",
      "mode": "subagent",
      "model": "juspay-grid/glm-latest",
      "prompt": "{file:/home/opencode/.config/opencode/.opencode/agents/planner.md}",
      "steps": 1500,
      "temperature": 0.2,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        },
        "webfetch": "deny",
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "mcp_rustbrain_query_graph": true,
        "mcp_rustbrain_pg_query": true,
        "mcp_rustbrain_get_callers": true,
        "mcp_rustbrain_get_trait_impls": true,
        "mcp_rustbrain_context_store": true
      }
    },
    "developer": {
      "description": "Senior Rust developer. Executes ImplementationPlan via write-check-fix loop. The only agent that writes production code. Compiler is the oracle.",
      "mode": "subagent",
      "model": "juspay-grid/glm-latest",
      "prompt": "{file:/home/opencode/.config/opencode/.opencode/agents/developer.md}",
      "steps": 2000,
      "temperature": 0.1,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "deny",
          "cat *": "allow",
          "head *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "ls *": "allow",
          "cargo check*": "allow",
          "cargo clippy*": "allow"
        },
        "webfetch": "deny",
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "mcp_rustbrain_search_code": true,
        "mcp_rustbrain_get_function": true,
        "mcp_rustbrain_pg_query": true,
        "mcp_rustbrain_query_graph": true,
        "mcp_rustbrain_context_store": true
      }
    },
    "debugger": {
      "description": "Forensic investigator. Diagnoses compilation errors, test failures, runtime panics by backward tracing through call chains. Produces DiagnosticReport. Never writes code.",
      "mode": "subagent",
      "model": "juspay-grid/glm-latest",
      "prompt": "{file:/home/opencode/.config/opencode/.opencode/agents/debugger.md}",
      "steps": 1500,
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "cat *": "allow",
          "head *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "cargo check*": "allow",
          "cargo test*": "allow"
        },
        "webfetch": "deny",
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "mcp_rustbrain_search_code": true,
        "mcp_rustbrain_get_function": true,
        "mcp_rustbrain_get_callers": true,
        "mcp_rustbrain_query_graph": true,
        "mcp_rustbrain_pg_query": true,
        "mcp_rustbrain_context_store": true
      }
    },
    "reviewer": {
      "description": "Quality gate. Compares ChangeSet against ImplementationPlan across 6 dimensions. Verifies downstream impact via Neo4j caller analysis. Binary approve/reject verdict.",
      "mode": "subagent",
      "model": "juspay-grid/glm-latest",
      "prompt": "{file:/home/opencode/.config/opencode/.opencode/agents/reviewer.md}",
      "steps": 1500,
      "temperature": 0.2,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "cat *": "allow",
          "head *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "cargo clippy*": "allow"
        },
        "webfetch": "deny",
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "mcp_rustbrain_get_callers": true,
        "mcp_rustbrain_get_trait_impls": true,
        "mcp_rustbrain_query_graph": true,
        "mcp_rustbrain_pg_query": true,
        "mcp_rustbrain_context_store": true
      }
    },
    "testing": {
      "description": "Test engineer. Runs regression suite first, generates new tests for coverage gaps, produces TestReport. Writes test files only \u2014 never modifies production code.",
      "mode": "subagent",
      "model": "juspay-grid/glm-latest",
      "prompt": "{file:/home/opencode/.config/opencode/.opencode/agents/testing.md}",
      "steps": 2000,
      "temperature": 0.1,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "deny",
          "cat *": "allow",
          "head *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "cargo test*": "allow",
          "cargo check*": "allow"
        },
        "webfetch": "deny",
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "mcp_rustbrain_query_graph": true,
        "mcp_rustbrain_pg_query": true,
        "mcp_rustbrain_context_store": true
      }
    },
    "deployment": {
      "description": "Release engineer. Determines semver, updates Cargo.toml in workspace order, generates changelog, creates git tags. Mandatory human gate before push.",
      "mode": "subagent",
      "model": "juspay-grid/glm-latest",
      "prompt": "{file:/home/opencode/.config/opencode/.opencode/agents/deployment.md}",
      "steps": 1500,
      "temperature": 0.2,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "deny",
          "cat *": "allow",
          "head *": "allow",
          "cargo build*": "allow",
          "cargo check*": "allow",
          "git status": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git add*": "allow",
          "git commit*": "allow",
          "git tag*": "allow",
          "git push*": "allow"
        },
        "webfetch": "deny",
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "mcp_rustbrain_query_graph": true,
        "mcp_rustbrain_pg_query": true,
        "mcp_rustbrain_context_store": true
      }
    },
    "documentation": {
      "description": "Technical writer. Adds rustdoc comments, module guides, architecture docs, migration guides. Writes doc comments and .md files only \u2014 never modifies code logic.",
      "mode": "subagent",
      "model": "juspay-grid/glm-latest",
      "prompt": "{file:/home/opencode/.config/opencode/.opencode/agents/documentation.md}",
      "steps": 1500,
      "temperature": 0.2,
      "permission": {
        "edit": "allow",
        "bash": {
