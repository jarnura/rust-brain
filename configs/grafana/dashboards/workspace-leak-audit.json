        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rustbrain_leak_cleanup_volumes_removed_total", "legendFormat": "cleaned_volumes", "refId": "C"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rustbrain_leak_cleanup_containers_removed_total", "legendFormat": "cleaned_containers", "refId": "D"}
