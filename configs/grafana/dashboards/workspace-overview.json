        {
          "datasource": {"type": "postgres", "uid": "postgres"},
          "rawSql": "SELECT w.name AS workspace_name, a.operation, a.actor, a.old_status, a.new_status, a.detail, a.created_at FROM workspace_audit_log a JOIN workspaces w ON w.id = a.workspace_id ORDER BY a.created_at DESC LIMIT 100",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Recent Workspace Activity",
      "type": "table"
    },
    {
      "datasource": {"type": "postgres", "uid": "postgres"},
