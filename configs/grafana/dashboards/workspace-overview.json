        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "postgres"},
          "rawSql": "SELECT COALESCE(EXTRACT(EPOCH FROM AVG(index_completed_at - index_started_at)), 0)::numeric AS avg_index_seconds FROM workspaces WHERE status = 'ready' AND index_started_at IS NOT NULL AND index_completed_at IS NOT NULL",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Avg Index Duration",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "green", "mode": "fixed"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "reqps"
        },
        "overrides": []
      },
