        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "created_at"}]
      },
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "postgres"},
          "rawSql": "SELECT w.name, w.status, w.index_error, w.index_stage, EXTRACT(EPOCH FROM (NOW() - w.updated_at))::int AS secs_since_update, w.updated_at FROM workspaces w WHERE w.status IN ('error', 'cloning', 'indexing') ORDER BY w.updated_at DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Workspaces Needing Attention (Error / Cloning / Indexing)",
      "type": "table"
    },
    {
      "datasource": {"type": "postgres", "uid": "postgres"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": "/.*failed.*/"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/.*_done.*/"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]},
          {"matcher": {"id": "byRegexp", "options": "/.*leak.*/"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]}
        ]
