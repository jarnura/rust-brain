    },
    {
      "datasource": {"type": "postgres", "uid": "postgres"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "filterable": true,
            "inspect": false
          },
          "mappings": [
            {"type": "value", "options": {"pending": {"text": "⏳ Pending", "color": "super-light-blue"}, "cloning": {"text": "🔄 Cloning", "color": "orange"}, "indexing": {"text": "⚡ Indexing", "color": "blue"}, "ready": {"text": "✅ Ready", "color": "green"}, "error": {"text": "❌ Error", "color": "red"}, "archived": {"text": "📦 Archived", "color": "purple"}}}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "text", "value": null}]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "name"},
            "properties": [{"id": "custom.width", "value": 150}]
          },
          {
            "matcher": {"id": "byName", "options": "status"},
            "properties": [{"id": "custom.cellOptions", "value": {"type": "color-background"}}]
          },
          {
            "matcher": {"id": "byName", "options": "source_url"},
            "properties": [{"id": "custom.width", "value": 250}, {"id": "links", "value": [{"title": "Open Repo", "url": "${__data.fields.source_url}"}]}]
          },
          {
            "matcher": {"id": "byName", "options": "index_duration"},
            "properties": [{"id": "unit", "value": "s"}, {"id": "custom.cellOptions", "value": {"type": "sparkline"}}]
          }
        ]
      },
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 8},
      "id": 10,
      "options": {
        "footer": {"enablePagination": true, "fields": ""},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "created_at"}]
      },
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "postgres"},
          "rawSql": "SELECT w.name, w.source_type, w.source_url, w.status, w.index_stage, w.index_error, EXTRACT(EPOCH FROM (w.index_completed_at - w.index_started_at))::numeric AS index_duration, w.created_at, w.updated_at FROM workspaces w ORDER BY w.created_at DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "All Workspaces",
      "type": "table"
    },
    {
      "datasource": {"type": "postgres", "uid": "postgres"},
