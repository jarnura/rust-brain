      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "postgres"},
          "rawSql": "SELECT date_trunc('day', index_completed_at) AS time, EXTRACT(EPOCH FROM AVG(index_completed_at - index_started_at))::numeric AS avg_duration_secs FROM workspaces WHERE status = 'ready' AND index_started_at IS NOT NULL AND index_completed_at IS NOT NULL GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "title": "Indexing Duration Trend",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "postgres", "uid": "postgres"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "filterable": true,
            "inspect": false
          },
          "mappings": [
            {"type": "value", "options": {"create": {"color": "green"}, "clone_start": {"color": "blue"}, "clone_done": {"color": "green"}, "clone_failed": {"color": "red"}, "index_start": {"color": "blue"}, "index_done": {"color": "green"}, "index_failed": {"color": "red"}, "volume_create": {"color": "blue"}, "volume_remove": {"color": "purple"}, "volume_create_failed": {"color": "red"}, "volume_remove_failed": {"color": "red"}, "container_spawn": {"color": "blue"}, "container_stop": {"color": "purple"}, "container_remove_failed": {"color": "red"}, "archive": {"color": "purple"}, "cleanup_failed": {"color": "red"}, "leak_detected": {"color": "orange"}, "leak_cleaned": {"color": "green"}}}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "text", "value": null}]
          }
        },
        "overrides": [
